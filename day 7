// 7.3 -- Protected: Accessible only by child/derived classes
#include <iostream>
using namespace std;

class Parent {
protected:
    int secretCode = 1234; // Shielded from main, visible to Child
};

class child : public Parent {
public:    
    void accessOfSecretCode() {
        cout << "Secret code accessed via Inheritance: " << secretCode << "\n";
    }
};

// ==============================================
// рЯТО PROBLEM 02: CONSTRUCTORS рЯПЧпЄП
// рЯУЭ Task: Initializing objects automatically
// ==============================================

// 2.1 -- Default Constructor: No parameters required
class wifiConnection {
public:    
    string networkName;
    string password;
    
    wifiConnection() {
        networkName = "ACTFibre";
        password = "BJP wons";
    }
    
    void showDetails() {
        cout << "WiFi: " << networkName << " | PWD: " << password << "\n"; 
    }
};

// 2.2 -- Parameterized Constructor: Pass data at creation
class Student {
public:
    string name;
    int id;

    Student(string studentName, int studentID){
        name = studentName;
        id = studentID;
    }

    void displayDetails() { cout << "Student: " << name << " (ID: " << id << ")\n"; }    
};

// ==============================================
// рЯТО PROBLEM 03: ENCAPSULATION рЯТК
// рЯУЭ Task: Data hiding and Controlled Access (Getters/Setters)
// рЯЦЉпЄП Concept: Binding variables & methods into one unit
// ==============================================

class bankAccount {
private:
    int balance;    

public:   
    void setBalance(int amount) {
        if(amount >= 0) {
            balance = amount;
        } else {
            cout << "Error: Invalid Amount!\n";
        }
    }
    
    int getbalance() { return balance; }
};

// ==============================================
// рЯТО PROBLEM 04: ABSTRACTION рЯМЂпЄП
// рЯУЭ Task: Hiding implementation, showing only essentials
// ==============================================

/* 
 * Abstract Class: A blueprint that cannot be instantiated.
 * Abstract Method: A method declared without an implementation (Pure Virtual).
 */

int main() {
    cout << "--- Access Specifier Demo ---\n";
    child obj1;
    obj1.accessOfSecretCode();

    cout << "\n--- Constructor Demo ---\n";
    wifiConnection wifi;
    wifi.showDetails();
    
    Student std1("Abhishek", 101); // Abhishek Aggarwal, Age 24
    std1.displayDetails();

    cout << "\n--- Encapsulation Demo ---\n";
    bankAccount myAcc;
    myAcc.setBalance(6000);
    cout << "Verified Balance: " << myAcc.getbalance() << "\n";

    return 0;
}

